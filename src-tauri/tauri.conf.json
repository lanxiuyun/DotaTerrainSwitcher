{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DotaTerrainSwitcher",
  "version": "7.41.0",
  "identifier": "com.lanxiuyun.dota-terrain-switcher",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "刀刀小工具",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Main app capabilities",
          "local": true,
          "windows": ["main"],
          "permissions": [
            "core:default",
            "opener:default",
            "dialog:default",
            "fs:default",
            "store:default",
            "updater:default"
          ]
        }
      ]
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://api.upgrade.toolsetlink.com/upgrade/v1/tauri/check?appKey=DMFXx6_TXa7MjpHTWEc5eQ"
      ],
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
